<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.sayy.Mapper.UserMapper">

    <resultMap id="UserResultMap" type="com.example.sayy.Entity.UserEntity">
        <id property="username" column="username"/>
        <result property="pwd" column="pwd"/>
        <result property="role" column="role"/>
        <result property="enabled" column="enabled"/>
        <result property="createdAt" column="created_at"/>
        <result property="employeeNo" column="employee_no"/>
    </resultMap>

    <select id="selectByUsername" resultMap="UserResultMap">
        SELECT username, pwd, role, enabled, created_at, employee_no
        FROM users
        WHERE username = #{username}
    </select>

    <insert id="insert" parameterType="com.example.sayy.Entity.UserEntity">
        INSERT INTO users (username, pwd, role, enabled, employee_no)
        VALUES (#{username}, #{pwd}, #{role}, #{enabled}, #{employeeNo})
    </insert>

    <delete id="deleteByUsername">
        DELETE FROM users WHERE username = #{username}
    </delete>

    <select id="existsByUsername" resultType="int">
        SELECT CASE WHEN COUNT(1) > 0 THEN 1 ELSE 0 END
        FROM users
        WHERE username = #{username}
    </select>
</mapper>

